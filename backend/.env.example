# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/entities.db

# ── Data sources ─────────────────────────────────────────────────────────
# Which sources to activate (comma-separated: hawaii, connecticut, los_angeles, wyoming)
ENABLED_SOURCES=hawaii,connecticut,los_angeles

# Socrata optional app token (increases rate limits on public APIs)
SOCRATA_APP_TOKEN=

# Override default API URLs if needed
HAWAII_API_URL=https://data.honolulu.gov/resource/9k54-ztb8.json
CONNECTICUT_API_URL=https://data.ct.gov/resource/n7gm-hh35.json
LA_API_URL=https://data.lacity.org/resource/r4uk-afju.json

# Wyoming – requires Apify paid token
WYOMING_APIFY_TOKEN=
WYOMING_APIFY_ACTOR=parseforge/wyoming-business-scraper

# ── Collection ───────────────────────────────────────────────────────────
DEFAULT_LIMIT=500
# TARGET_DATE=2026-05-05   # leave empty to use today
OUTPUT_CSV_DIR=data/exports

# ── Scheduler ────────────────────────────────────────────────────────────
SCHEDULER_HOUR=0
SCHEDULER_MINUTE=5

# ── API server ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Domain check ─────────────────────────────────────────────────────────
# Seconds to wait between RDAP requests (be polite!)
DOMAIN_CHECK_DELAY=0.5
